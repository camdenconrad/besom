diff --git a/fsw/inc/cfe_psp_besom.h b/fsw/inc/cfe_psp_besom.h
new file mode 100644
index 0000000..8ac310e
--- /dev/null
+++ b/fsw/inc/cfe_psp_besom.h
@@ -0,0 +1,57 @@
+/************************************************************************
+ * Besom sensor bus -- the flight-software side of the harness's step protocol.
+ *
+ * Simulated vehicle state arrives INSIDE the timebase step rather than on a
+ * socket of its own. The timebase module installs it before advancing simulated
+ * time, so an app cannot observe time T without also observing the state that
+ * belongs to T, and there is no queue anywhere whose depth the host could decide.
+ *
+ * This replaced a UDP feed that besom_io drained on its own cycle. How many
+ * datagrams had arrived by the time it looked was the kernel's business, so the
+ * app published a sample one full cycle off between otherwise identical runs.
+ * Both runs were internally consistent, which is why no existing check saw it.
+ ************************************************************************/
+
+#ifndef CFE_PSP_BESOM_H
+#define CFE_PSP_BESOM_H
+
+#include "common_types.h"
+
+/**
+ * Largest sensor block the timebase will carry, in bytes.
+ *
+ * The PSP never interprets the contents -- it is a byte pipe with a sequence
+ * number -- so the layout stays a private contract between the harness and the
+ * app that consumes it, and this header needs no revision when that changes.
+ */
+#define CFE_PSP_BESOM_SENSOR_MAX 256
+
+/**
+ * \brief Fetch the sensor block delivered with the tick being processed.
+ *
+ * \par Threading
+ * Callable ONLY from the timebase thread, meaning from inside a timer callback
+ * bound to "cFS-Master". This is enforced, not advisory: called from a task
+ * thread it returns #CFE_PSP_ERROR and writes nothing.
+ *
+ * The restriction is the mechanism. A task thread would read whatever the
+ * timebase thread last wrote, with no defined relationship to that task's own
+ * notion of time -- reintroducing exactly the host-dependent sampling this
+ * design removes. On the timebase thread the read is ordered against the write
+ * by program order, and the step protocol serialises the next tick behind the
+ * previous acknowledgement, so no other tick can be in flight.
+ *
+ * \param[in]  dest      Destination buffer.
+ * \param[in]  max_size  Capacity of \p dest. Fails if the block is larger.
+ * \param[out] out_size  Bytes written.
+ * \param[out] out_seq   Monotonic block counter. Unchanged between two calls
+ *                       means the harness supplied no new state for this tick;
+ *                       the caller decides whether that is stale or an error.
+ *
+ * \return #CFE_PSP_SUCCESS, or #CFE_PSP_ERROR on the wrong thread, before any
+ *         block has been installed, on a null argument, or if \p max_size is
+ *         too small.
+ */
+int32 CFE_PSP_Besom_GetSensorBlock(void *dest, uint32 max_size, uint32 *out_size, uint32 *out_seq);
+
+#endif /* CFE_PSP_BESOM_H */
