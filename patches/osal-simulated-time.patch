+
+/*
+ * Block on `chan` until somebody wakes us.
+ *
+ * We go NOT-READY and give up the token in one atomic step, so a waker cannot
+ * miss us: it either sees us blocked on `chan` (and marks us ready), or we have
+ * not blocked yet and will re-test the condition under the same lock.
+ */
+void OS_Coop_Block_Impl(const void *chan)
+{
+    if (!OS_Coop.enabled || OS_Coop_Self == NULL)
+    {
+        return;
+    }
+
+    pthread_mutex_lock(&OS_Coop.mutex);
+
+    OS_Coop_Self->ready = false;
+    OS_Coop_Self->chan  = chan;
+    OS_Coop.running     = false;
+    pthread_cond_broadcast(&OS_Coop.cond);
+
+    /* Wait to be made ready BY SOMEONE ELSE -- that is the whole point. */
+    while (!OS_Coop_Self->ready)
+    {
+        pthread_cond_wait(&OS_Coop.cond, &OS_Coop.mutex);
+    }
+
+    OS_Coop_Self->chan = NULL;
+    OS_Coop_TakeToken(OS_Coop_Self);
+
+    pthread_mutex_unlock(&OS_Coop.mutex);
+}
+
+/*
+ * Block on `chan`, but no later than a simulated deadline.
+ *
+ * Woken by either OS_Coop_Wake_Impl(chan) -- someone gave the thing we want -- or
+ * by the tick thread when simulated time reaches the deadline. A timed wait needs
+ * both, and both must be synchronous, or the timeout itself becomes a race.
+ */
+void OS_Coop_BlockUntil_Impl(const void *chan, unsigned long long wake_usec)
+{
+    if (!OS_Coop.enabled || OS_Coop_Self == NULL)
+    {
+        return;
+    }
+
+    pthread_mutex_lock(&OS_Coop.mutex);
+
+    OS_Coop_Self->ready     = false;
+    OS_Coop_Self->chan      = chan;
+    OS_Coop_Self->wake_usec = wake_usec;
+    OS_Coop.running         = false;
+    pthread_cond_broadcast(&OS_Coop.cond);
+
+    while (!OS_Coop_Self->ready)
+    {
+        pthread_cond_wait(&OS_Coop.cond, &OS_Coop.mutex);
+    }
+
+    OS_Coop_Self->chan      = NULL;
+    OS_Coop_Self->wake_usec = 0;
+    OS_Coop_TakeToken(OS_Coop_Self);
+
+    pthread_mutex_unlock(&OS_Coop.mutex);
+}
+
+/*
+ * Wake everything blocked on `chan`, right now.
+ *
+ * Called by the task performing the give/put, while it still holds the token. The
+ * woken tasks become runnable at a defined instant in the schedule; which of them
+ * actually runs next is then decided by key order, not by Linux.
