+/*
+ * Block until simulated time advances past `until_usec`, or until it advances at
+ * all (whichever comes first). Callers that are waiting on some *other* event
+ * with a timeout use this to re-poll that event once per granted tick, so their
+ * timeout is measured in simulated time rather than host time.
+ */
+void OS_SimTime_WaitTick_Impl(unsigned long long until_usec)
+{
+    unsigned long long start;
