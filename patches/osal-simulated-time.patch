+    pthread_mutex_lock(&OS_SimTime.mutex);
+    active = OS_SimTime.active;
+    pthread_mutex_unlock(&OS_SimTime.mutex);
+
+    return active;
+}
+
+unsigned long long OS_SimTime_GetUsec_Impl(void)
+{
+    unsigned long long usec;
+
+    pthread_mutex_lock(&OS_SimTime.mutex);
+    usec = OS_SimTime.usec;
+    pthread_mutex_unlock(&OS_SimTime.mutex);
+
+    return usec;
