+/*
+ * Pending on something OUTSIDE the simulation -- a host socket, or the harness
+ * itself. Such a task must not merely give up the token: it must leave the ready
+ * set entirely, or the scheduler would keep picking it and stall waiting for a
+ * task that cannot proceed.
+ */
+void OS_Coop_ExternalBegin_Impl(void)
+{
+    if (!OS_Coop.enabled || OS_Coop_Self == NULL)
+    {
+        return;
+    }
+
+    pthread_mutex_lock(&OS_Coop.mutex);
+    OS_Coop_Self->ready    = false;
+    OS_Coop_Self->external = true;
+    OS_Coop.running        = false;
+    pthread_cond_broadcast(&OS_Coop.cond);
+    pthread_mutex_unlock(&OS_Coop.mutex);
+}
+
+void OS_Coop_ExternalEnd_Impl(void)
+{
+    if (!OS_Coop.enabled || OS_Coop_Self == NULL)
+    {
+        return;
+    }
+
+    pthread_mutex_lock(&OS_Coop.mutex);
+    OS_Coop_Self->external = false;
+    OS_Coop_Self->ready    = true;
+    OS_Coop_TakeToken(OS_Coop_Self);
+    pthread_mutex_unlock(&OS_Coop.mutex);
+}
