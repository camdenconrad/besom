diff --git a/src/os/posix/src/os-impl-tasks.c b/src/os/posix/src/os-impl-tasks.c
index a7d9cb46..74662a50 100644
--- a/src/os/posix/src/os-impl-tasks.c
+++ b/src/os/posix/src/os-impl-tasks.c
@@ -748,11 +748,551 @@ void OS_TaskExit_Impl(void)
  *           See prototype for argument/return detail
  *
  *-----------------------------------------------------------------*/
+/*
+ * ---- Simulated-time task delay (Besom) ----
+ *
+ * OS_TaskDelay is otherwise a real clock_nanosleep on the HOST clock, which
+ * means any task that sleeps runs OUTSIDE a simulated timebase entirely. With
+ * an externally-synced timebase (see OS_TimeBaseCreate's external_sync), the
+ * scheduler's ticks are under the simulation's control but sleeping tasks are
+ * not -- so their work lands at host-scheduling-dependent moments and telemetry
+ * is not reproducible. cFS apps that sleep (cf, hs, mm, cs, fm) exhibit exactly
+ * this.
+ *
+ * Fix: OSAL maintains its own simulated microsecond counter, advanced by the
+ * timebase helper thread on every externally-synced tick, and OS_TaskDelay
+ * pends on it rather than on the host clock.
+ *
+ * This lives in the POSIX layer because the shared layer is OS-agnostic and may
+ * not use pthreads. OSAL cannot read the PSP's clock (the PSP sits *above*
+ * OSAL), so OSAL must track simulated time itself -- the tick is the only
+ * information that crosses the boundary, and it is enough.
+ */
+static struct
+{
+    pthread_mutex_t    mutex;
+    pthread_cond_t     cond;
+    unsigned long long usec;
+    bool               active; /* set once an external-sync tick has arrived */
+} OS_SimTime = {PTHREAD_MUTEX_INITIALIZER, PTHREAD_COND_INITIALIZER, 0, false};
+
+/*
+ * The timebase helper thread is the only advancer of simulated time. If it ever
+ * pended on the sim clock it would deadlock waiting for itself, so it is marked
+ * and always takes the real-sleep path.
+ */
+static __thread bool OS_SimTime_IsTickThread = false;
+
+void OS_SimTime_MarkTickThread_Impl(void)
+{
+    OS_SimTime_IsTickThread = true;
+}
+
+void OS_SimTime_Advance_Impl(uint32 usec)
+{
+    pthread_mutex_lock(&OS_SimTime.mutex);
+    OS_SimTime.usec += usec;
+    OS_SimTime.active = true;
+    pthread_cond_broadcast(&OS_SimTime.cond);
+    pthread_mutex_unlock(&OS_SimTime.mutex);
+}
+
+/*
+ * ---- Cooperative deterministic scheduler (Besom) ----
+ *
+ * The last source of nondeterminism after the clock is under control: within a
+ * single granted tick, several cFE tasks become runnable at once and the HOST
+ * scheduler picks the order. Whichever runs first sees a different world, so an
+ * event can land on this tick or the next, and whole telemetry streams slide.
+ *
+ * The fix is a token. Only one OSAL task executes at a time, and when a task
+ * blocks it hands the token to the LOWEST-NUMBERED task waiting for it. Task ids
+ * are assigned in creation order, which is fixed by the startup script -- so the
+ * order in which runnable tasks execute is fixed too, and does not depend on
+ * Linux.
+ *
+ * This is not free: cFS loses real parallelism, so it runs slower in wall-clock
+ * terms. In a simulation that is the correct trade -- there is no physical rate
+ * to keep up with, only reproducibility to preserve.
+ *
+ * ENABLED BY $BESOM_COOP. Off by default: every blocking call in OSAL has to
+ * release the token, and any blocking path that is missed would deadlock the
+ * whole flight software rather than merely perturb it. Opt-in keeps that risk
+ * away from ordinary runs.
+ */
+#define OS_COOP_MAX_TASKS 64
+
+/*
+ * A task's place in the deterministic schedule.
+ *
+ * `ready` is the load-bearing field. It is set by WHOEVER WAKES THE TASK, at the
+ * instant it wakes it, while that waker holds the token. The earlier design let a
+ * task mark itself ready when its thread happened to come off a semaphore -- which
+ * meant a fast-waking high-numbered task could take the token before a
+ * low-numbered task had even arrived to ask for it. Readiness was observed
+ * asynchronously, so the race moved rather than disappearing.
+ */
+typedef struct
+{
+    bool               used;
+    uint32             key;       /* OSAL task id: creation order, fixed by the startup script */
+    bool               ready;     /* eligible to run */
+    const void        *chan;      /* the object it is blocked on, NULL if runnable */
+    bool               external;  /* pending on something outside the simulation (a host socket) */
+    unsigned long long wake_usec; /* simulated deadline, 0 if none */
+} OS_Coop_Task_t;
+
+static struct
+{
+    pthread_mutex_t mutex;
+    pthread_cond_t  cond;
+    bool            enabled;
+    bool            running;     /* somebody holds the token */
+    uint32          running_key;
+    OS_Coop_Task_t  tasks[OS_COOP_MAX_TASKS];
+} OS_Coop = {PTHREAD_MUTEX_INITIALIZER, PTHREAD_COND_INITIALIZER, false, false, 0, {{0}}};
+
+static __thread OS_Coop_Task_t *OS_Coop_Self = NULL;
+
+void OS_Coop_Init_Impl(void)
+{
+    const char *env = getenv("BESOM_COOP");
+
+    OS_Coop.enabled = (env != NULL && env[0] == '1');
+
+    if (OS_Coop.enabled)
+    {
+        printf("OSAL(besom): cooperative deterministic scheduler ENABLED\n");
+    }
+}
+
+bool OS_Coop_Enabled_Impl(void)
+{
+    return OS_Coop.enabled;
+}
+
+/*
+ * True only for a thread that has actually JOINED the schedule.
+ *
+ * The distinction matters: cFE's main thread is not an OSAL task, so it never
+ * joins. If it took the cooperative paths, its Block would be a no-op and it
+ * would spin forever instead of pending -- which is exactly what deadlocked boot
+ * the first time. Threads outside the schedule must keep using the ordinary
+ * blocking primitives.
+ */
+bool OS_Coop_InSched_Impl(void)
+{
+    return OS_Coop.enabled && OS_Coop_Self != NULL;
+}
+
+/* Caller holds the lock. Is `me` the lowest-keyed task that could run? */
+static bool OS_Coop_MayRun(const OS_Coop_Task_t *me)
+{
+    uint32 i;
+
+    if (OS_Coop.running || !me->ready)
+    {
+        return false;
+    }
+
+    for (i = 0; i < OS_COOP_MAX_TASKS; ++i)
+    {
+        const OS_Coop_Task_t *t = &OS_Coop.tasks[i];
+
+        if (t->used && t->ready && t->key < me->key)
+        {
+            return false; /* someone earlier in the order can run */
+        }
+    }
+
+    return true;
+}
+
+/* Caller holds the lock. Park until it is our turn, then take the token. */
+static void OS_Coop_TakeToken(OS_Coop_Task_t *me)
+{
+    struct timespec deadline;
+    int             rc = 0;
+
+    while (!OS_Coop_MayRun(me))
+    {
+        /* BESOM DIAGNOSTIC: if we wait a long time, say who is holding the token
+         * and what everyone else is doing. A cooperative scheduler that stalls is
+         * otherwise completely opaque. */
+        clock_gettime(CLOCK_REALTIME, &deadline);
+        deadline.tv_sec += 3;
+
+        rc = pthread_cond_timedwait(&OS_Coop.cond, &OS_Coop.mutex, &deadline);
+
+        if (rc == ETIMEDOUT)
+        {
+            uint32 i;
+            printf("COOP-STALL: key=%lu waiting. running=%d holder=%lu\n", (unsigned long)me->key,
+                   (int)OS_Coop.running, (unsigned long)OS_Coop.running_key);
+            for (i = 0; i < OS_COOP_MAX_TASKS; ++i)
+            {
+                if (OS_Coop.tasks[i].used)
+                {
+                    printf("   task key=%lu ready=%d chan=%p ext=%d wake=%llu\n",
+                           (unsigned long)OS_Coop.tasks[i].key, (int)OS_Coop.tasks[i].ready,
+                           OS_Coop.tasks[i].chan, (int)OS_Coop.tasks[i].external,
+                           OS_Coop.tasks[i].wake_usec);
+                }
+            }
+            fflush(stdout);
+        }
+    }
+
+    OS_Coop.running     = true;
+    OS_Coop.running_key = me->key;
+}
+
+void OS_Coop_Acquire_Impl(void)
+{
+    if (!OS_Coop.enabled || OS_Coop_Self == NULL)
+    {
+        return;
+    }
+
+    pthread_mutex_lock(&OS_Coop.mutex);
+    OS_Coop_Self->ready = true;
+    OS_Coop_TakeToken(OS_Coop_Self);
+    pthread_mutex_unlock(&OS_Coop.mutex);
+}
+
+void OS_Coop_Release_Impl(void)
+{
+    if (!OS_Coop.enabled || OS_Coop_Self == NULL)
+    {
+        return;
+    }
+
+    pthread_mutex_lock(&OS_Coop.mutex);
+    OS_Coop.running = false;
+    pthread_cond_broadcast(&OS_Coop.cond);
+    pthread_mutex_unlock(&OS_Coop.mutex);
+}
+
+void OS_Coop_Join_Impl(uint32 key)
+{
+    uint32 i;
+
+    if (!OS_Coop.enabled)
+    {
+        return;
+    }
+
+    pthread_mutex_lock(&OS_Coop.mutex);
+
+    for (i = 0; i < OS_COOP_MAX_TASKS; ++i)
+    {
+        if (!OS_Coop.tasks[i].used)
+        {
+            OS_Coop.tasks[i].used      = true;
+            OS_Coop.tasks[i].key       = key;
+            OS_Coop.tasks[i].ready     = true;
+            OS_Coop.tasks[i].chan      = NULL;
+            OS_Coop.tasks[i].external  = false;
+            OS_Coop.tasks[i].wake_usec = 0;
+            OS_Coop_Self               = &OS_Coop.tasks[i];
+            break;
+        }
+    }
+
+    if (OS_Coop_Self != NULL)
+    {
+        OS_Coop_TakeToken(OS_Coop_Self);
+    }
+
+    pthread_mutex_unlock(&OS_Coop.mutex);
