diff --git a/src/os/posix/src/os-impl-tasks.c b/src/os/posix/src/os-impl-tasks.c
index a7d9cb46..419d100d 100644
--- a/src/os/posix/src/os-impl-tasks.c
+++ b/src/os/posix/src/os-impl-tasks.c
@@ -748,11 +748,133 @@ void OS_TaskExit_Impl(void)
  *           See prototype for argument/return detail
  *
  *-----------------------------------------------------------------*/
+/*
+ * ---- Simulated-time task delay (Besom) ----
+ *
+ * OS_TaskDelay is otherwise a real clock_nanosleep on the HOST clock, which
+ * means any task that sleeps runs OUTSIDE a simulated timebase entirely. With
+ * an externally-synced timebase (see OS_TimeBaseCreate's external_sync), the
+ * scheduler's ticks are under the simulation's control but sleeping tasks are
+ * not -- so their work lands at host-scheduling-dependent moments and telemetry
+ * is not reproducible. cFS apps that sleep (cf, hs, mm, cs, fm) exhibit exactly
+ * this.
+ *
+ * Fix: OSAL maintains its own simulated microsecond counter, advanced by the
+ * timebase helper thread on every externally-synced tick, and OS_TaskDelay
+ * pends on it rather than on the host clock.
+ *
+ * This lives in the POSIX layer because the shared layer is OS-agnostic and may
+ * not use pthreads. OSAL cannot read the PSP's clock (the PSP sits *above*
+ * OSAL), so OSAL must track simulated time itself -- the tick is the only
+ * information that crosses the boundary, and it is enough.
+ */
+static struct
+{
+    pthread_mutex_t    mutex;
+    pthread_cond_t     cond;
+    unsigned long long usec;
+    bool               active; /* set once an external-sync tick has arrived */
+} OS_SimTime = {PTHREAD_MUTEX_INITIALIZER, PTHREAD_COND_INITIALIZER, 0, false};
+
+/*
+ * The timebase helper thread is the only advancer of simulated time. If it ever
+ * pended on the sim clock it would deadlock waiting for itself, so it is marked
+ * and always takes the real-sleep path.
+ */
+static __thread bool OS_SimTime_IsTickThread = false;
+
+void OS_SimTime_MarkTickThread_Impl(void)
+{
+    OS_SimTime_IsTickThread = true;
+}
+
+void OS_SimTime_Advance_Impl(uint32 usec)
+{
+    pthread_mutex_lock(&OS_SimTime.mutex);
+    OS_SimTime.usec += usec;
+    OS_SimTime.active = true;
+    pthread_cond_broadcast(&OS_SimTime.cond);
+    pthread_mutex_unlock(&OS_SimTime.mutex);
+}
+
+/*
+ * True when the simulation owns the clock and the caller is a task that may
+ * legitimately pend on it (i.e. not the tick thread, which advances it).
+ */
+bool OS_SimTime_Active_Impl(void)
+{
+    bool active;
+
+    if (OS_SimTime_IsTickThread)
+    {
+        return false;
+    }
+
+    pthread_mutex_lock(&OS_SimTime.mutex);
+    active = OS_SimTime.active;
+    pthread_mutex_unlock(&OS_SimTime.mutex);
+
+    return active;
+}
+
+unsigned long long OS_SimTime_GetUsec_Impl(void)
+{
+    unsigned long long usec;
+
+    pthread_mutex_lock(&OS_SimTime.mutex);
+    usec = OS_SimTime.usec;
+    pthread_mutex_unlock(&OS_SimTime.mutex);
+
+    return usec;
+}
+
+/*
+ * Block until simulated time advances past `until_usec`, or until it advances at
+ * all (whichever comes first). Callers that are waiting on some *other* event
+ * with a timeout use this to re-poll that event once per granted tick, so their
+ * timeout is measured in simulated time rather than host time.
+ */
+void OS_SimTime_WaitTick_Impl(unsigned long long until_usec)
+{
+    unsigned long long start;
+
+    pthread_mutex_lock(&OS_SimTime.mutex);
+    start = OS_SimTime.usec;
+    while (OS_SimTime.usec == start && OS_SimTime.usec < until_usec)
+    {
+        pthread_cond_wait(&OS_SimTime.cond, &OS_SimTime.mutex);
+    }
+    pthread_mutex_unlock(&OS_SimTime.mutex);
+}
+
 int32 OS_TaskDelay_Impl(uint32 millisecond)
 {
     struct timespec sleep_end;
     int             status;
 
+    /*
+     * Simulated path: pend until the simulation has granted enough time.
+     *
+     * Not used before the first tick (nothing is driving the clock yet, so a
+     * task would hang forever) and never used on the tick thread itself.
+     */
+    if (!OS_SimTime_IsTickThread)
+    {
+        pthread_mutex_lock(&OS_SimTime.mutex);
+        if (OS_SimTime.active)
+        {
+            unsigned long long deadline = OS_SimTime.usec + (unsigned long long)millisecond * 1000;
+
+            while (OS_SimTime.usec < deadline)
+            {
+                pthread_cond_wait(&OS_SimTime.cond, &OS_SimTime.mutex);
+            }
+            pthread_mutex_unlock(&OS_SimTime.mutex);
+            return OS_SUCCESS;
+        }
+        pthread_mutex_unlock(&OS_SimTime.mutex);
+    }
+
     clock_gettime(CLOCK_MONOTONIC, &sleep_end);
     sleep_end.tv_sec  += millisecond / 1000;
     sleep_end.tv_nsec += 1000000 * (millisecond % 1000);
