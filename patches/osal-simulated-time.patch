+/*
+ * Sleep until simulated time reaches `wake_usec`.
+ *
+ * The tick thread wakes us (see OS_Coop_WakeDelays_Impl) as part of advancing the
+ * clock, so a delay expires at a defined point in the schedule rather than
+ * whenever the host clock happens to fire.
+ */
+void OS_Coop_DelayUntil_Impl(unsigned long long wake_usec)
+{
+    if (!OS_Coop.enabled || OS_Coop_Self == NULL)
+    {
+        return;
+    }
+
+    pthread_mutex_lock(&OS_Coop.mutex);
+
+    OS_Coop_Self->ready     = false;
+    OS_Coop_Self->wake_usec = wake_usec;
+    OS_Coop.running         = false;
+    pthread_cond_broadcast(&OS_Coop.cond);
+
+    while (!OS_Coop_Self->ready)
+    {
+        pthread_cond_wait(&OS_Coop.cond, &OS_Coop.mutex);
+    }
+
+    OS_Coop_Self->wake_usec = 0;
+    OS_Coop_TakeToken(OS_Coop_Self);
+
+    pthread_mutex_unlock(&OS_Coop.mutex);
+}
+
+/* Called by the tick thread after it advances simulated time. */
+void OS_Coop_WakeDelays_Impl(unsigned long long now_usec)
+{
+    uint32 i;
+
+    if (!OS_Coop.enabled)
+    {
+        return;
+    }
+
+    pthread_mutex_lock(&OS_Coop.mutex);
+
+    for (i = 0; i < OS_COOP_MAX_TASKS; ++i)
+    {
+        OS_Coop_Task_t *t = &OS_Coop.tasks[i];
+
+        if (t->used && !t->ready && t->wake_usec != 0 && now_usec >= t->wake_usec)
+        {
+            t->ready     = true;
+            t->wake_usec = 0;
+        }
+    }
+
+    pthread_cond_broadcast(&OS_Coop.cond);
+    pthread_mutex_unlock(&OS_Coop.mutex);
+}
